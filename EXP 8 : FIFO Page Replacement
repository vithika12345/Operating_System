#include <stdio.h>

int main() {
    int n, f, i, j, k = 0, flag;
    
    printf("Enter number of pages: ");
    scanf("%d", &n);

    int pages[n];
    printf("Enter page reference string:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &pages[i]);
    }

    printf("Enter number of frames: ");
    scanf("%d", &f);

    int frames[f];
    int faults = 0, hits = 0;

    // Initialize frames with -1
    for(i = 0; i < f; i++)
        frames[i] = -1;

    printf("\nPage\tFrames\n");

    for(i = 0; i < n; i++) {
        flag = 0;

        // Check if page already in frame (HIT)
        for(j = 0; j < f; j++) {
            if(frames[j] == pages[i]) {
                flag = 1;
                hits++;
                break;
            }
        }

        // Page Fault
        if(flag == 0) {
            frames[k] = pages[i];
            k = (k + 1) % f; // FIFO replacement
            faults++;
        }

        // Print frames
        printf("%d\t", pages[i]);
        for(j = 0; j < f; j++) {
            if(frames[j] != -1)
                printf("%d ", frames[j]);
            else
                printf("- ");
        }
        printf("\n");
    }

    printf("\nTotal Page Faults = %d", faults);
    printf("\nTotal Page Hits = %d\n", hits);

    return 0;
}
